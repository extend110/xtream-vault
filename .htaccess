Options -Indexes

# ── Rewrite ──────────────────────────────────────────────────────
RewriteEngine On

# Custom Headers durchlassen (für CSRF-Token)
RewriteRule .* - [E=HTTP_X_CSRF_TOKEN:%{HTTP:X-CSRF-Token}]

# lang/-Verzeichnis sperren
RewriteRule ^lang/ - [F,L]

# data/-Verzeichnis komplett sperren
RewriteRule ^data/ - [F,L]

# ── Sensitive Dateien sperren ─────────────────────────────────────
<FilesMatch "\.(json|log)$">
    Require all denied
</FilesMatch>

# Interne PHP-Dateien – nicht direkt aufrufbar
<FilesMatch "^(config|auth|cron|cache_builder|backup|notify)\.php$">
    Require all denied
</FilesMatch>

# ── Sicherheits-Header ───────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "no-referrer"
</IfModule>

# lang/-Verzeichnis sperren (nur PHP-include, kein direkter Zugriff)
<FilesMatch "^(de|en|fr|es|it)\.php$">
    Require all denied
</FilesMatch>
